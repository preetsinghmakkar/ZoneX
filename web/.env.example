# ============================================
# CLERK AUTHENTICATION (Required)
# Get from: https://dashboard.clerk.com
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================
# WALLETCONNECT (Required for wallet connection)
# Get from: https://cloud.walletconnect.com
# ============================================
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=YOUR_PROJECT_ID_HERE

# ============================================
# ALCHEMY RPC (Required for blockchain reads)
# Get from: https://www.alchemy.com
# ============================================
NEXT_PUBLIC_ALCHEMY_KEY=YOUR_ALCHEMY_KEY_HERE

# ============================================
# CHAIN CONFIG
# 1 = Mainnet, 11155111 = Sepolia
# ============================================
NEXT_PUBLIC_DEFAULT_CHAIN=11155111
